{
  "expo": {
    "name": "Cromsen",
    "slug": "cromsen-mobile",
    "scheme": "cromsen-mobile",
    "version": "1.0.0",
    "icon": "./assets/icons/CromsenAppicon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icons/CromsenAppicon.png",
      "backgroundColor": "#ffffff",
      "resizeMode": "contain"
    },

    "ios": {
      "icon": "./assets/icons/CromsenAppicon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.cromsen.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cromsen.app",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY_HERE"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/CromsenAppicon.png",
        "backgroundColor": "#000000"
      }
    },
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "eas": {
        "projectId": "2232435b-63d7-4f7f-b05d-34e161dafff2"
      }
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.20",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ],
      "expo-asset"
    ],
    "newArchEnabled": true
  }
}
