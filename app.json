{
  "expo": {
    "name": "Cromsen",
    "slug": "cromsen-mobile",
    "scheme": "cromsen-mobile",
    "version": "1.0.0",
    "icon": "./assets/icons/Cromsen-Appicon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icons/Cromsen-Appicon.png",
      "backgroundColor": "#ffffff",
      "resizeMode": "contain"
    },
    "runtimeVersion": "1.0.0",
    "ios": {
      "icon": "./assets/icons/Cromsen-Appicon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.cromsen.app"
    },
    "android": {
      "package": "com.cromsen.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/Cromsen-Appicon.png",
        "backgroundColor": "#000000"
      }
    },
    "updates": {},
    "extra": {
      "eas": {}
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.0",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 23
          }
        }
      ],
      "expo-asset"
    ],
    "newArchEnabled": false
  }
}